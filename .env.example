# GitSight environment configuration
# Copy this file to .env and adjust values for your environment.
# The application reads these at startup via config.py.

# Server
GITSIGHT_HOST=127.0.0.1
GITSIGHT_PORT=8000

# CORS — set to your frontend origin(s) in production (comma-separated)
# Example: GITSIGHT_ALLOWED_ORIGINS=https://app.yourdomain.com
GITSIGHT_ALLOWED_ORIGINS=*

# Clone directory — must be writable by the process user
# Defaults to backend/.cache/repo_clones if not set
# GITSIGHT_CLONE_DIR=/tmp/gitsight_clones

# Result caching — set to 0 to disable the (repo_url, HEAD sha) cache
GITSIGHT_CACHE=1

# SQLite database path (cache + instructor overrides)
# Defaults to backend/.cache/gitsight.db if not set
# GITSIGHT_DB_PATH=/var/lib/gitsight/gitsight.db

# Optional LLM polish for verdict explanations (1 to enable; off by default)
GITSIGHT_EXPLAIN_LLM=0
